# URL of your deployed Eve preview instance (used by the Eve live preview).
# Deploy registry/eve/competitor-intel as an Eve project on Vercel, then set this
# to its origin, e.g. https://my-eve-agent.vercel.app
EVE_PREVIEW_URL=

# Anthropic API key for the Flue live preview, which runs in-process in the
# Next.js API route. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Bright Data API key — powers the Deep Search (SERP API) and Chat with YouTube
# (Web Unlocker) agents. Create one at https://brightdata.com/cp/setting/users
BRIGHTDATA_API_KEY=
# Zone names for those products (defaults: serp_api / web_unlocker1).
BRIGHTDATA_SERP_ZONE=
BRIGHTDATA_UNLOCKER_ZONE=

# context.dev API key — powers the AI SEO Audit and Extract DESIGN.md agents,
# which fetch pages, styleguides, brand assets, and screenshots through the SDK.
# Create one at https://context.dev
CONTEXT_DEV_API_KEY=

# Bright Data Browser API credentials for the Browser agent's managed,
# anti-bot-resistant remote Chromium. Your zone "username:password", e.g.
# brd-customer-<id>-zone-<zone>:<password>. https://brightdata.com/cp/zones
BRIGHTDATA_BROWSER_AUTH=
